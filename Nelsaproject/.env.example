DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
# Optional: also write logs to logs/django.log (default: stdout only; needed on Render without LOG_TO_FILE)
LOG_TO_FILE=
DEPLOYMENT_ENV=development
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# Production/staging database (required there): postgres://user:pass@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

COMPANY_NAME=GARANTI EXPRESS
COMPANY_SUPPORT_EMAIL=
# GARANTI fixed contact number — phone, WhatsApp links, MoMo pay instructions, booking receipts
COMPANY_SUPPORT_PHONE=+237675315422
# Shown on MTN/Orange instructions (defaults to national digits from COMPANY_SUPPORT_PHONE)
PAYMENT_MOMO_MERCHANT_PHONE=
# Reference prefix in dial instructions (e.g. GAR12 for booking group 12)
PAYMENT_REFERENCE_PREFIX=GAR
# Run email/SMS jobs immediately after enqueue (recommended unless you use a worker/cron).
NOTIFICATION_FLUSH_JOBS_INLINE=True
# Public site URL (https on production). Used for sitemaps, emails, QR links, and JSON-LD. Set to your real domain (e.g. https://yoursite.onrender.com) for correct Google indexing.
PUBLIC_SITE_URL=http://127.0.0.1:8000
# flutterwave = hosted checkout (MTN/Orange/card via Flutterwave) | manual = legacy dial + transaction ID
PAYMENT_PROVIDER=flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_CURRENCY=XAF
# Simulate payments locally when FLUTTERWAVE_SECRET_KEY is empty (True recommended for dev)
FLUTTERWAVE_SIMULATE=True

# flutterwave = hosted checkout (MTN/Orange/card via Flutterwave) | manual = legacy dial + transaction ID
PAYMENT_PROVIDER=flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_CURRENCY=XAF
# Simulate payments locally when FLUTTERWAVE_SECRET_KEY is empty (True recommended for dev)
FLUTTERWAVE_SIMULATE=True
FLUTTERWAVE_WEBHOOK_HASH=

PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret
# Optional: hex HMAC of raw JSON body (header X-Webhook-Body-Signature)
PAYMENT_WEBHOOK_HMAC_SECRET=
PAYMENT_WEBHOOK_MAX_SKEW_SECONDS=300
PAYMENT_WEBHOOK_MAX_RETRIES=3
PAYMENT_WEBHOOK_TRUSTED_IPS=
PAYMENT_WEBHOOK_RATE_LIMIT_PER_MIN=120

# Optional provider-specific webhook signatures
PAYSTACK_WEBHOOK_SECRET=
# Comma-separated ops emails; optional webhook failure alerts
ALERT_EMAIL_RECIPIENTS=
ALERT_ON_WEBHOOK_FAILURE=False
ALERT_ESCALATION_RECIPIENTS=
ONCALL_OWNER=ops-team
ALERT_WEBHOOK_REJECTED_THRESHOLD_5M=3
ALERT_WEBHOOK_DEAD_LETTER_THRESHOLD=1
ALERT_SMS_FAILED_THRESHOLD=20
ALERT_PENDING_BOOKINGS_THRESHOLD=100

# Optional: protect /internal/metrics/ for automated monitors
METRICS_AUTH_TOKEN=
VERIFY_TICKET_RATE_LIMIT_PER_MIN=120
VERIFY_SMS_RECEIPT_RATE_LIMIT_PER_MIN=60

# Optional: separate secret for QR ticket signing (defaults to DJANGO_SECRET_KEY if empty)
TICKET_SIGNING_SECRET=
TICKET_MAX_AGE_SECONDS=10368000

# --- Live SMS (Twilio): set all of these on production; trial accounts only send to Verified Caller IDs ---
SMS_ENABLED=True
# twilio = real sends | mock = log only (safe for local dev)
SMS_PROVIDER=twilio
# Optional alias for "From" if you prefer not to use TWILIO_PHONE_NUMBER (E.164, e.g. +15551234567)
SMS_FROM_NUMBER=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number with SMS capability (E.164). Same value as SMS_FROM_NUMBER if you only set one.
TWILIO_PHONE_NUMBER=

# --- WhatsApp booking confirmations ---
#
# OPTION A — FREE (no Twilio, no card): manual send from your GARANTI phone (+237675315422)
#   WHATSAPP_ENABLED=True
#   WHATSAPP_ADMIN_HANDOFF=True
#   After admin confirms, browser opens WhatsApp with the receipt — press Send once.
#
# OPTION B — Automatic send via Twilio API (needs Twilio account; sandbox is free for testing)
#   1. Sign up at https://www.twilio.com (trial works; card may be asked to upgrade for production)
#   2. Copy Account SID (AC…) + Auth Token from console.twilio.com
#   3. Join Twilio WhatsApp Sandbox (Messaging → Try WhatsApp) — passengers must join too for tests
#   4. Set below and WHATSAPP_PROVIDER=twilio, WHATSAPP_ADMIN_HANDOFF=False
#
WHATSAPP_ENABLED=True
WHATSAPP_PROVIDER=mock
WHATSAPP_ADMIN_HANDOFF=True
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set True only if you also want SMS on confirm (usually leave False when using WhatsApp)
BOOKING_CONFIRMATION_SMS_ALSO=False

AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=NelsaNdo
